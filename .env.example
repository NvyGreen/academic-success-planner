# Absolute path to the SQLite database file.
#   local:  C:/Users/you/.../course_reg/sample_courses.db
#   server: /home/USERNAME/academic-success-planner/prod.db
SQLITE3_DB=path/to/database/file

# Generate a strong key (at least 32 chars): python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=

# On a fresh deploy, build_prod_db.py prints SEED_EMAIL and SEED_PWD — paste them here.
SEED_EMAIL=
# A pbkdf2_sha256 hash, NOT plaintext (login verifies with pbkdf2_sha256.verify).
# Generate: python -c "from passlib.hash import pbkdf2_sha256; print(pbkdf2_sha256.hash('your-password'))"
SEED_PWD=
