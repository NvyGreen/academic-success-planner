# Copy this file to .env in the repo root and fill in the values:
#   cp .env.example .env
#
# This .env is used for BOTH local development and deployment. A few values differ
# between the two; those differences are noted inline. For the PythonAnywhere
# deploy, follow DEPLOY.md (its WSGI entrypoint imports create_app() directly).

# --- Flask CLI ---
# Used by `flask run` locally. The WSGI deploy imports create_app() directly and
# doesn't read FLASK_APP, but DO set FLASK_DEBUG=0 in production: debug mode exposes
# an interactive debugger and must never be enabled in prod.
FLASK_APP=course_reg
FLASK_DEBUG=1   # 1 = local dev (auto-reload + debugger); set to 0 in production

# --- App config (required everywhere; create_app() refuses to boot without these) ---

# Path to the SQLite database file.
#   local:  any path, e.g. dev.db  -> created and seeded with sample courses
#           automatically on first run, so there's nothing else to set up.
#   deploy: an ABSOLUTE path, e.g. /home/USERNAME/academic-success-planner/prod.db
#           (relative paths break under WSGI). Build it with: python build_prod_db.py
SQLITE3_DB=dev.db

# Session signing key. Must be at least 32 chars and not a common placeholder,
# or create_app() exits. Generate one:
#   python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=

# Initial login account (create_app() requires both to boot).
#   local:  pick an email, and set SEED_PWD to a pbkdf2_sha256 HASH (not plaintext);
#           log in afterward with the plaintext you hashed:
#             python -c "from passlib.hash import pbkdf2_sha256; print(pbkdf2_sha256.hash('your-password'))"
#   deploy: `python build_prod_db.py` prompts for a password and prints ready-to-paste
#           SEED_EMAIL / SEED_PWD lines — paste both here.
SEED_EMAIL=
SEED_PWD=
